# Large binary files (model checkpoints)
*.pt
*.pth
*.pkl
*.pickle
*.h5
*.hdf5

# Data files (downloaded during runtime)
data/*.csv
data/*.tab
*.csv.gz

# Outputs directory - exclude everything except key results
# First, exclude all outputs
outputs/*

# Keep the .gitkeep and specific result directories
!outputs/.gitkeep
!outputs/gradients/
!outputs/sar_validation/
!outputs/tox21_adme_results/
!outputs/figures/

# But within those directories, exclude large binary files
outputs/**/*.pt
outputs/**/*.npz

# Explicitly keep the main gradient matrix (small, required for HPC)
!outputs/gradients/gnn_conflict_matrices.npz

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db
desktop.ini
nul

# Temporary files
*.tmp
*.temp
*.bak

# SLURM output files
slurm-*.out
*.out
*.err
